{
  "name": "playright-project",
  "version": "1.0.0",
  "description": "Playwright UI automation framework",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",

    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",

    "test:headed": "playwright test --headed",

    "test:dev": "cross-env ENV=dev playwright test",
    "test:stage": "cross-env ENV=stage playwright test",
    "test:prod": "cross-env ENV=prod playwright test",

    "test:dev:chromium": "cross-env ENV=dev playwright test --project=chromium",
    "test:stage:chromium": "cross-env ENV=stage playwright test --project=chromium",
    "test:prod:chromium": "cross-env ENV=prod playwright test --project=chromium",

    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "keywords": [
    "playwright",
    "automation",
    "typescript",
    "qa",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.7.2",
    "cross-env": "^10.1.0"
  }
}